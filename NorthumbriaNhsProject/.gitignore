## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
*.log

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# OS-generated files
.DS_Store
Thumbs.db

# Visual Studio 2019/2022
.vs/
.vscode/

# Rider
.idea/
*.sln.iml

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# DotCover
*.dotCover

# NCrunch
*.ncrunch*
.*crunch*.local.xml

# Coverlet
coverage*.json
coverage*.xml
coverage*.info

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Azure Pipelines
.azure-pipelines/

# Code analysis
*.ruleset
*.editorconfig
.stylecop
.stylecop.*

# Global tool packages
.nuget/

# Paket dependency manager
.paket/
paket-files/

# JetBrains Rider
.idea/
*.sln.iml

# Local NuGet packages
*.nupkg
*.snupkg

# npm / Node.js for frontend apps
node_modules/
dist/
wwwroot/lib/

# Environment files
.env
*.env.*

# Secrets
secrets.json

# macOS
*.DS_Store

# Windows
ehthumbs.db
Thumbs.db

# Linux
*~

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Dotnet CLI
project.lock.json
project.fragment.lock.json
artifacts/

# Backup & temporary files
*.bak
*.tmp
*.swp

# Other
.idea/
